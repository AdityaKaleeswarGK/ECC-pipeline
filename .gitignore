# Ignore everything by default
*

# Allow these root-level files
!.gitignore
!README.md
!ECC_FINAL_pipeline.ipynb

# Allow the Mondorian_CQR folder itself
!Mondorian_CQR/

# Allow result files inside Mondorian_CQR (CSVs, PNGs, JSON)
!Mondorian_CQR/*.csv
!Mondorian_CQR/*.png
!Mondorian_CQR/*.json

# Explicitly ignore notebooks and data files inside Mondorian_CQR
Mondorian_CQR/*.ipynb
Mondorian_CQR/*.xlsx
Mondorian_CQR/*.npz